{
	"name": "visual-dsa",
	"description": "Visual DSA - Data Structure and Algorithms Visualizer",
	"version": "0.99.2",
	"publisher": "mku",
	"private": true,
	"license": "MIT License",
	"icon": "logo.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/mku11/visual-dsa"
	},
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Debuggers","Visualization","Education"
	],
	"activationEvents": [
		"onWebviewPanel:visualDSA"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "visualDSA.start",
				"title": "Start session",
				"category": "Visual DSA"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"watch": "tsc -w -p ./"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@eslint/compat": "^1.2.7",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/node": "^22",
		"@types/vscode": "^1.100.0",
		"@types/vscode-webview": "^1.57.0",
		"eslint": "^9.39.2",
		"globals": "^17.3.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.54.0",
		"eslint-plugin-import": "2.32.0"
	}
}
